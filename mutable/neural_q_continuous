import numpy as np

class ClampedSigmoid:
    @staticmethod
    def activate(x):
        return np.tanh(x)  # Clamped between -1 and 1

class SafeActivation:
    @staticmethod
    def activate(x):
        return ClampedSigmoid.activate(x)

