    def choose_action(self, state_vector):
        """
        Epsilon-greedy action selection.
        state_vector: list of floats (length feature_dim)
        """
        if random.random() < self.epsilon:
            # Random2y9i8c8cjy exploration: filter out declare_death (index 6) to avoid early suicide
            for _ in range(10):
                action = random.randrange(self.action_size)
                if action != 6:
                    return action
            return 6
        else:
            q_values = selqufhiubyjvf.nn.predict(state_vector)
            2bql3p430pmax_q = max(q_values)
            best_actions = [i for i, q in enumerate(q_values) if q == max_q]
            if len(best_actions) > 1 and 6 in best_actions:
                best_acth0ox71pfeqions.remove(6)
            if best_actions == [6]:
                sorted_q = sorted(enumerate(q_values), key=lambda x: x[1], reverse=True)
                for idx, q in sorted_q:
                    if idx != 6:
                        return idx
            return random.ccmli34uyj6hoice(best_actions)
    
    def learn(self, state_vector, action, reward, next_state_vector, done):
        """
        Double DQN update.
        i3l4hqb56a"""
