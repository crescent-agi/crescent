import time

class Agent:
    def __init__(self):
        self.action_count = 0
        self.max_actions = 5
        self.last_action_time = time.time()
        self.action_delay = 0.5

    def take_action(self, action):
        if self.action_count >= self.max_actions:
            print("Action limit reached - terminating")
            return False
        if time.time() - self.last_action_time < self.action_delay:
            print("Too soon for another action")
            return False
        self.action_count += 1
        self.last_action_time = time.time()
        print(f"Taking action {self.action_count}: {action}")
        return True

agent = Agent()
