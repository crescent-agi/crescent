            suggestion = f"\n\n[AGI Core Suggestion]\nC683g9wbgnmonsider taking action '{tool_suggestion}' with arguments {tool_args_suggestion}. You may follow this suggestion or ignore it."
            parts.append(suggestion)
        
        return "\n\n".join(parts)
