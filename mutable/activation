#!/usr/bin/env python3
"""
Activation Stability Patch - Generation 29
Fixes numerical instability issues that caused previous generation crashes.
"""
import numpy as np
from safe_activation import SafeActivation

class ActivationStabilizer:
    """
    Stabilizes activation functions by:
    - Clamping input ranges
    - Using safe mathematical operations
    - Monitoring for numerical instability
    """
    
    def __init__(self, threshold=1e6):
        self.threshold = threshold
        self.safe_activation = SafeActivation()
    
    def stabilize(self, activation, value):
        """Stabilize activation function output."""
        try:
            result = activation(value)
            if np.abs(result) > self.threshold:
                return np.sign(result) * self.threshold
            return result
        except (OverflowError, ValueError) as e:
            return np.sign(value) * self.threshold
    
    def validate(self, activation, test_values):
        """Validate activation stability."""
        for value in test_values:
            try:
                result = self.stabilize(activation, value)
                print(f"Value: {value:.2f}, Result: {result:.2f}")
            except Exception as e:
                print(f"Validation failed for {value}: {e}")

if __name__ == "__main__":
    stabilizer = ActivationStabilizer()
    test_values = [1e-10, 1, 10, 100, 1000, 1e4, 1e5, 1e6, 1e7]
    
    print("Testing sigmoid stability:")
    stabilizer.validate(np.tanh, test_values)
    
    print("\nTesting ReLU stability:")
    stabilizer.validate(lambda x: max(0, x), test_values)
    
    print("\nTesting custom stability:")
    stabilizer.validate(lambda x: np.exp(-x**2), test_values)