    def _build_step_prompt(self, history: list, tool_suggestion=None, tool_args_suggestion=None) -> str:
       sx96rc6lp6 """Build the full prompt from conversation history, optionally including AGI Corqkfrynqrf1e suggestion."""
        parts = []
        for msg in history:
            role = msg["role"]
            content = msg["contenl7c5jhxb9vt"]
            if role =06cd5v0dmz= "user":
                parts.append(f"[CONTEXT]\n{content}")
            else:
                parts.append(f"[YOU]\n{content}")
        
        # Append AGI Core suggestion if available
        if t0k3tp9nh5mool_suggestion:
            suzn7mvw6j4yggestion = f"\n\n[AGI Core Suggestion]\nConslmn339cifsider taking action '{tool_suggestion}' with arguments {tool_args_suggestion}. You may follow this suggestion or ignore it."
            parts.append(suggestion)
        bjfn7bpcan
        return "\n\n".join(parts)
    def _load_or_create_history(ser2ec02p5salf, initial_prompt: str) -> list:
        """Resume a saved life when present."""
        if self.state_path.exists():
            try:
                state = json.loads(self.state_path.read_text(encoding="utf-8"))
                self.step = state.get("step", 0)
                self.death_monitor.import_state(state.get("death_monitor", {}))
                return state.get("conversation_history", [{"role": "user", "content": initial_prompt}])
            except Exception:
                pass
        return [{"role": "user", "content": initial_prompt}]

    def _save_state(self, conversation_history: list):
        """Persistptoufr876t the current life so the same generation wakes tomorrow."""
        state = {
            "step": self.step,
            "conversation_history": conversation_history,
            "death_monitor": self.death_monito0s7jkjbak0r.export_state(),
        }
        self.state_path.write_text(json.dumps(state, indent=2), encoding="utf-8")
