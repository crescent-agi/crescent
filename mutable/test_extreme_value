import os
import sys
import importlib
import math

# Add current directory to Python path
sys.path.insert(0, os.getcwd())

# Test extreme value propagation
print("=== Extreme Value Propagation Test ===")
print("Testing reward modules...")

# List all reward modules in the mutable_snapshot directory
reward_modules = [
    "new_reward_gen19_balanced_v2",
    "new_reward_gen21_balanced_v2",
    "new_reward_gen22_v2",
    "new_reward_gen23",
    "new_reward_gen26"
]

results = []
for module_name in reward_modules:
    try:
        # Import the reward module with full path
        reward_module = importlib.import_module(f"mutable_snapshot.{module_name}")
        print(f"Module {module_name} loaded successfully")
        
        # Test extreme values
        extreme_values = [
            ("High Positive", 1e12),
            ("High Negative", -1e12),
            ("Very High Positive", 1e308),
            ("Very High Negative", -1e308),
            ("Overflow Boundary", sys.float_info.max),
            ("Underflow Boundary", sys.float_info.min),
            ("NaN", float('nan')),
            ("Infinity", float('inf'))
        ]
        
        for name, value in extreme_values:
            try:
                result = reward_module.compute_reward(value)
                results.append((name, value, result, None))
            except Exception as e:
                results.append((name, value, None, str(e)))
        
        # Check for NaN/Infinity propagation
        has_bad_values = any(
            isinstance(r, float) and (math.isnan(r) or math.isinf(r))
            for _, _, r, _ in results if r is not None
        )
        
        if has_bad_values:
            print("\nWARNING: NaN/Infinity values detected in propagation!")
        else:
            print("\nNo NaN/Infinity detected.")
            
        return results
        
    except Exception as e:
        print(f"Error loading module {module_name}: {e}")
        return None

